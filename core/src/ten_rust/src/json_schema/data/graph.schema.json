{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/$defs/graph",
  "$defs": {
    "graph": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "import_uri": {
          "type": "string",
          "anyOf": [
            {
              "format": "uri-reference"
            },
            {
              "pattern": "^\\$\\{app_base_dir\\}.*$"
            }
          ],
          "minLength": 1
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/graphNode"
          }
        },
        "connections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/graphConnection"
          }
        },
        "exposed_messages": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "name"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "cmd_in",
                  "cmd_out",
                  "data_in",
                  "data_out",
                  "audio_frame_in",
                  "audio_frame_out",
                  "video_frame_in",
                  "video_frame_out"
                ]
              },
              "name": {
                "$ref": "#/$defs/alphanumericCharacters"
              },
              "extension": {
                "$ref": "#/$defs/alphanumericCharacters"
              },
              "subgraph": {
                "$ref": "#/$defs/alphanumericCharacters"
              }
            },
            "oneOf": [
              {
                "required": [
                  "extension"
                ],
                "not": {
                  "required": [
                    "subgraph"
                  ]
                }
              },
              {
                "required": [
                  "subgraph"
                ],
                "not": {
                  "required": [
                    "extension"
                  ]
                }
              }
            ]
          }
        },
        "exposed_properties": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name"
            ],
            "properties": {
              "extension": {
                "$ref": "#/$defs/alphanumericCharacters"
              },
              "subgraph": {
                "$ref": "#/$defs/alphanumericCharacters"
              },
              "name": {
                "$ref": "#/$defs/alphanumericCharacters"
              }
            },
            "oneOf": [
              {
                "required": [
                  "extension"
                ],
                "not": {
                  "required": [
                    "subgraph"
                  ]
                }
              },
              {
                "required": [
                  "subgraph"
                ],
                "not": {
                  "required": [
                    "extension"
                  ]
                }
              }
            ]
          }
        }
      },
      "oneOf": [
        {
          "required": [
            "import_uri"
          ],
          "not": {
            "anyOf": [
              {
                "required": [
                  "nodes"
                ]
              },
              {
                "required": [
                  "connections"
                ]
              },
              {
                "required": [
                  "exposed_messages"
                ]
              },
              {
                "required": [
                  "exposed_properties"
                ]
              }
            ]
          }
        },
        {
          "not": {
            "required": [
              "import_uri"
            ]
          }
        }
      ]
    },
    "notEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "alphanumericCharacters": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "path_in_msg_conversion": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\[\\d+\\])*(\\.[A-Za-z_][A-Za-z0-9_]*(\\[\\d+\\])*)*$"
    },
    "msgDest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "app": {
          "$ref": "#/$defs/notEmptyString"
        },
        "extension": {
          "$ref": "#/$defs/alphanumericCharacters"
        },
        "subgraph": {
          "$ref": "#/$defs/alphanumericCharacters"
        },
        "selector": {
          "$ref": "#/$defs/alphanumericCharacters"
        },
        "msg_conversion": {
          "$ref": "#/$defs/msgConversion"
        }
      },
      "oneOf": [
        {
          "required": [
            "extension"
          ],
          "properties": {
            "app": {},
            "extension": {},
            "msg_conversion": {}
          },
          "additionalProperties": false
        },
        {
          "required": [
            "subgraph"
          ],
          "properties": {
            "subgraph": {},
            "msg_conversion": {}
          },
          "additionalProperties": false
        },
        {
          "required": [
            "selector"
          ],
          "properties": {
            "selector": {}
          },
          "additionalProperties": false
        }
      ]
    },
    "msgSource": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "app": {
          "$ref": "#/$defs/notEmptyString"
        },
        "extension": {
          "$ref": "#/$defs/alphanumericCharacters"
        },
        "subgraph": {
          "$ref": "#/$defs/alphanumericCharacters"
        },
        "selector": {
          "$ref": "#/$defs/alphanumericCharacters"
        }
      },
      "oneOf": [
        {
          "required": [
            "extension"
          ],
          "properties": {
            "app": {},
            "extension": {}
          },
          "additionalProperties": false
        },
        {
          "required": [
            "subgraph"
          ],
          "properties": {
            "subgraph": {}
          },
          "additionalProperties": false
        },
        {
          "required": [
            "selector"
          ],
          "properties": {
            "selector": {}
          },
          "additionalProperties": false
        }
      ]
    },
    "graphNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "extension",
            "subgraph",
            "selector"
          ]
        },
        "name": {
          "$ref": "#/$defs/alphanumericCharacters"
        },
        "addon": {
          "$ref": "#/$defs/alphanumericCharacters"
        },
        "app": {
          "$ref": "#/$defs/notEmptyString"
        },
        "extension_group": {
          "$ref": "#/$defs/alphanumericCharacters"
        },
        "graph": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "import_uri"
          ],
          "properties": {
            "import_uri": {
              "type": "string",
              "anyOf": [
                {
                  "format": "uri-reference"
                },
                {
                  "pattern": "^\\$\\{app_base_dir\\}.*$"
                }
              ],
              "minLength": 1
            }
          }
        },
        "filter": {
          "$ref": "#/$defs/filter"
        },
        "property": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "object",
                "$ref": "#/$defs/validPropertyObject"
              },
              {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/validPropertyArrayItem"
                }
              },
              {
                "type": "boolean"
              }
            ]
          }
        }
      },
      "allOf": [
        {
          "required": [
            "type",
            "name"
          ]
        },
        {
          "oneOf": [
            {
              "properties": {
                "type": {
                  "const": "extension"
                },
                "name": {},
                "addon": {},
                "extension_group": {},
                "app": {},
                "property": {}
              },
              "required": [
                "type",
                "name",
                "addon"
              ],
              "additionalProperties": false
            },
            {
              "properties": {
                "type": {
                  "const": "subgraph"
                },
                "name": {},
                "graph": {},
                "property": {}
              },
              "required": [
                "type",
                "name",
                "graph"
              ],
              "additionalProperties": false
            },
            {
              "properties": {
                "type": {
                  "const": "selector"
                },
                "name": {},
                "filter": {}
              },
              "required": [
                "type",
                "name",
                "filter"
              ],
              "additionalProperties": false
            }
          ]
        }
      ]
    },
    "graphConnection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "app": {
          "$ref": "#/$defs/notEmptyString"
        },
        "extension": {
          "$ref": "#/$defs/alphanumericCharacters"
        },
        "subgraph": {
          "$ref": "#/$defs/alphanumericCharacters"
        },
        "selector": {
          "$ref": "#/$defs/alphanumericCharacters"
        },
        "cmd": {
          "$ref": "#/$defs/extensionCmdsInGraph"
        },
        "data": {
          "$ref": "#/$defs/extensionDatasInGraph"
        },
        "video_frame": {
          "$ref": "#/$defs/extensionDatasInGraph"
        },
        "audio_frame": {
          "$ref": "#/$defs/extensionDatasInGraph"
        }
      },
      "oneOf": [
        {
          "required": [
            "extension"
          ],
          "not": {
            "anyOf": [
              {
                "required": [
                  "subgraph"
                ]
              },
              {
                "required": [
                  "selector"
                ]
              }
            ]
          }
        },
        {
          "required": [
            "subgraph"
          ],
          "not": {
            "anyOf": [
              {
                "required": [
                  "extension"
                ]
              },
              {
                "required": [
                  "selector"
                ]
              }
            ]
          }
        },
        {
          "required": [
            "selector"
          ],
          "not": {
            "anyOf": [
              {
                "required": [
                  "extension"
                ]
              },
              {
                "required": [
                  "subgraph"
                ]
              }
            ]
          }
        }
      ]
    },
    "msgConversion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "rules"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "per_property"
          ]
        },
        "keep_original": {
          "type": "boolean"
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "path": {
                "$ref": "#/$defs/path_in_msg_conversion"
              },
              "conversion_mode": {
                "type": "string",
                "enum": [
                  "fixed_value",
                  "from_original"
                ]
              },
              "value": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "number"
                  }
                ]
              },
              "original_path": {
                "$ref": "#/$defs/notEmptyString"
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "conversion_mode": {
                      "const": "fixed_value"
                    }
                  },
                  "required": [
                    "conversion_mode"
                  ]
                },
                "then": {
                  "required": [
                    "value"
                  ],
                  "not": {
                    "required": [
                      "original_path"
                    ]
                  }
                },
                "else": {
                  "if": {
                    "properties": {
                      "conversion_mode": {
                        "const": "from_original"
                      }
                    },
                    "required": [
                      "conversion_mode"
                    ]
                  },
                  "then": {
                    "required": [
                      "original_path"
                    ],
                    "not": {
                      "required": [
                        "value"
                      ]
                    }
                  }
                }
              }
            ]
          }
        },
        "result": {
          "$ref": "#/$defs/msgConversion"
        }
      }
    },
    "extensionDatasInGraph": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "anyOf": [
          {
            "required": [
              "name"
            ]
          },
          {
            "required": [
              "names"
            ]
          }
        ],
        "properties": {
          "name": {
            "$ref": "#/$defs/alphanumericCharacters"
          },
          "names": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/alphanumericCharacters"
            }
          },
          "dest": {
            "$ref": "#/$defs/msgDests"
          },
          "source": {
            "$ref": "#/$defs/msgSources"
          }
        },
        "oneOf": [
          {
            "required": [
              "dest"
            ]
          },
          {
            "required": [
              "source"
            ]
          }
        ],
        "if": {
          "required": [
            "names"
          ]
        },
        "then": {
          "properties": {
            "dest": {
              "type": "array",
              "items": {
                "type": "object",
                "not": {
                  "required": [
                    "msg_conversion"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "extensionCmdsInGraph": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "anyOf": [
          {
            "required": [
              "name"
            ]
          },
          {
            "required": [
              "names"
            ]
          }
        ],
        "properties": {
          "name": {
            "$ref": "#/$defs/alphanumericCharacters"
          },
          "names": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/alphanumericCharacters"
            }
          },
          "dest": {
            "$ref": "#/$defs/msgDests"
          },
          "source": {
            "$ref": "#/$defs/msgSources"
          }
        },
        "oneOf": [
          {
            "required": [
              "dest"
            ]
          },
          {
            "required": [
              "source"
            ]
          }
        ],
        "if": {
          "required": [
            "names"
          ]
        },
        "then": {
          "properties": {
            "dest": {
              "type": "array",
              "items": {
                "type": "object",
                "not": {
                  "required": [
                    "msg_conversion"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "msgDests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/msgDest"
      }
    },
    "msgSources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/msgSource"
      }
    },
    "validPropertyObject": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "number"
          },
          {
            "type": "object",
            "$ref": "#/$defs/validPropertyObject"
          },
          {
            "type": "array",
            "items": {
              "$ref": "#/$defs/validPropertyArrayItem"
            }
          },
          {
            "type": "boolean"
          }
        ]
      }
    },
    "validPropertyArrayItem": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "object",
          "$ref": "#/$defs/validPropertyObject"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/validPropertyArrayItem"
          }
        },
        {
          "type": "boolean"
        }
      ]
    },
    "filter": {
      "oneOf": [
        {
          "$ref": "#/$defs/atomicFilter"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "and"
          ],
          "properties": {
            "and": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/filter"
              },
              "minItems": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "or"
          ],
          "properties": {
            "or": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/filter"
              },
              "minItems": 1
            }
          }
        }
      ]
    },
    "atomicFilter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "operator",
        "value"
      ],
      "properties": {
        "field": {
          "type": "string"
        },
        "operator": {
          "type": "string",
          "enum": [
            "exact",
            "regex"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}