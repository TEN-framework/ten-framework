{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$defs": {
    "encryptionConfiguration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "algorithm": {
          "type": "string",
          "enum": [
            "AES-CTR"
          ]
        },
        "params": {
          "if": {
            "properties": {
              "algorithm": {
                "const": "AES-CTR"
              }
            },
            "required": [
              "algorithm"
            ]
          },
          "then": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "key",
              "nonce"
            ],
            "properties": {
              "key": {
                "type": "string"
              },
              "nonce": {
                "type": "string"
              }
            }
          },
          "else": {
            "type": "object"
          }
        }
      }
    },
    "logLevels": {
      "type": "integer",
      "format": "int8",
      "enum": [
        1,
        2,
        3,
        4,
        5,
        6
      ]
    },
    "non_empty_non_localhost_uri": {
      "type": "string",
      "format": "uri",
      "minLength": 1,
      "not": {
        "const": "localhost"
      }
    },
    "endpoint": {
      "type": "string",
      // example.com:8080, 127.0.0.1:3000, etc.
      "pattern": "^[a-zA-Z0-9._-]+:[0-9]{1,5}$"
    },
    "notEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "alphanumericCharacters": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "path_in_msg_conversion": {
      "type": "string",
      // 1. Using X.Y.Z as a pattern, this represents object access.
      //    The number of connections with `.` can be unlimited.
      // 2. The rule for X/Y/Z/... is alphanumeric characters, or alphanumeric
      //    characters followed by `[]`, where the content inside the `[]` must
      //    only be numeric. This `[]` pattern represents array access.
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\[\\d+\\])*(\\.[A-Za-z_][A-Za-z0-9_]*(\\[\\d+\\])*)*$"
    },
    "valueType": {
      "type": "string",
      "enum": [
        "bool",
        "int8",
        "int16",
        "int32",
        "int64",
        "uint8",
        "uint16",
        "uint32",
        "uint64",
        "float32",
        "float64",
        "string",
        "buf",
        "ptr",
        "array",
        "object"
      ]
    },
    "selectorPattern": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "pattern"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "regex",
            "exact"
          ]
        },
        "pattern": {
          "$ref": "#/$defs/notEmptyString"
        }
      }
    },
    "tenConfiguration": {
      "type": "object",
      "properties": {
        "uri": {
          "$ref": "#/$defs/non_empty_non_localhost_uri"
        },
        // @{
        // TODO(Wei): The log_level and log_file below are for versions of ten
        // framework prior to 0.9. After most users have upgraded to 0.9, we
        // can and should remove the schema definitions for these 2 fields.
        "log_level": {
          "$ref": "#/$defs/logLevels"
        },
        "log_file": {
          "$ref": "#/$defs/notEmptyString"
        },
        // @}
        "deprecated_log": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "level": {
              "$ref": "#/$defs/logLevels"
            },
            "file": {
              "$ref": "#/$defs/notEmptyString"
            },
            "encryption": {
              "$ref": "#/$defs/encryptionConfiguration"
            }
          }
        },
        "long_running_mode": {
          "type": "boolean"
        },
        "one_event_loop_per_engine": {
          "type": "boolean"
        },
        "addon": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "preload_all": {
              "type": "boolean"
            }
          }
        },
        "services": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "telemetry": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "metrics": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean"
                    },
                    "exporter": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "type"
                      ],
                      "properties": {
                        "type": {
                          "type": "string",
                          "enum": [
                            "prometheus",
                            "otlp",
                            "console"
                          ]
                        },
                        "config": {
                          "type": "object"
                        }
                      },
                      "allOf": [
                        {
                          "if": {
                            "properties": {
                              "type": {
                                "const": "prometheus"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "config": {
                                "additionalProperties": false,
                                "properties": {
                                  "endpoint": {
                                    "type": "string",
                                    "pattern": "^[^:]+:[0-9]+$",
                                    "description": "HTTP server endpoint in format 'host:port'"
                                  },
                                  "path": {
                                    "type": "string",
                                    "pattern": "^/.*$"
                                  },
                                  "service_name": {
                                    "type": "string",
                                    "minLength": 1
                                  }
                                }
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "type": {
                                "const": "otlp"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "config": {
                                "additionalProperties": false,
                                "properties": {
                                  "endpoint": {
                                    "type": "string",
                                    "minLength": 1
                                  },
                                  "protocol": {
                                    "type": "string",
                                    "enum": [
                                      "grpc",
                                      "http"
                                    ]
                                  },
                                  "headers": {
                                    "type": "object",
                                    "patternProperties": {
                                      "^[A-Za-z0-9_-]+$": {
                                        "type": "string"
                                      }
                                    },
                                    "additionalProperties": false
                                  },
                                  "service_name": {
                                    "type": "string",
                                    "minLength": 1
                                  }
                                }
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "type": {
                                "const": "console"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "config": {
                                "additionalProperties": false,
                                "properties": {}
                              }
                            }
                          }
                        }
                      ]
                    }
                  }
                }
              }
            },
            "api": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "host": {
                  "type": "string"
                },
                "port": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 65535
                }
              }
            }
          }
        },
        "path_timeout": {
          "oneOf": [
            {
              "type": "integer",
              "format": "int64"
            },
            {
              "type": "object",
              "properties": {
                "in_path": {
                  "type": "integer",
                  "format": "int64"
                },
                "out_path": {
                  "type": "integer",
                  "format": "int64"
                }
              }
            }
          ]
        },
        "path_check_interval": {
          "type": "integer",
          "format": "int64"
        },
        "predefined_graphs": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "$ref": "#/$defs/alphanumericCharacters"
              },
              "auto_start": {
                "type": "boolean",
                "default": false
              },
              "singleton": {
                "type": "boolean",
                "default": false
              },
              "sync_stop_before_deinit": {
                "type": "boolean",
                "default": false
              },
              "graph": {
                "$ref": "#/$defs/graph"
              }
            }
          }
        },
        "log": {
          "$ref": "#/$defs/advancedLogConfiguration"
        }
      }
    },
    "advancedLogLevels": {
      "type": "string",
      "enum": [
        "off",
        "debug",
        "info",
        "warn",
        "error"
      ]
    },
    "advancedLogMatcher": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "$ref": "#/$defs/advancedLogLevels"
        },
        "category": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "advancedLogFormatter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "plain",
            "json"
          ]
        },
        "colored": {
          "type": "boolean"
        }
      }
    },
    "advancedLogEmitter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "config"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "console",
            "file",
            "otlp"
          ]
        },
        "config": {
          "type": "object"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "console"
              }
            }
          },
          "then": {
            "properties": {
              "config": {
                "additionalProperties": false,
                "required": [
                  "stream"
                ],
                "properties": {
                  "stream": {
                    "type": "string",
                    "enum": [
                      "stdout",
                      "stderr"
                    ]
                  },
                  "encryption": {
                    "$ref": "#/$defs/encryptionConfiguration"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "file"
              }
            }
          },
          "then": {
            "properties": {
              "config": {
                "additionalProperties": false,
                "required": [
                  "path"
                ],
                "properties": {
                  "path": {
                    "type": "string",
                    "minLength": 1
                  },
                  "encryption": {
                    "$ref": "#/$defs/encryptionConfiguration"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "otlp"
              }
            }
          },
          "then": {
            "properties": {
              "config": {
                "additionalProperties": false,
                "required": [
                  "endpoint"
                ],
                "properties": {
                  "endpoint": {
                    "type": "string",
                    "minLength": 1
                  },
                  "protocol": {
                    "type": "string",
                    "enum": [
                      "grpc",
                      "http"
                    ]
                  },
                  "headers": {
                    "type": "object",
                    "patternProperties": {
                      "^[A-Za-z0-9_-]+$": {
                        "type": "string"
                      }
                    },
                    "additionalProperties": false
                  },
                  "service_name": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        }
      ]
    },
    "advancedLogHandler": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "matchers",
        "formatter",
        "emitter"
      ],
      "properties": {
        "matchers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/advancedLogMatcher"
          }
        },
        "formatter": {
          "$ref": "#/$defs/advancedLogFormatter"
        },
        "emitter": {
          "$ref": "#/$defs/advancedLogEmitter"
        }
      }
    },
    "advancedLogConfiguration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "handlers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/advancedLogHandler"
          }
        }
      }
    }
  },
  "type": "object",
  "properties": {
    // @{
    // TODO(Wei): The _ten below is for versions of ten framework prior to 0.9.
    // After most users have upgraded to 0.9, we can and should remove the
    // schema definitions for the _ten field.
    "ten": {
      "$ref": "#/$defs/tenConfiguration"
    },
    "_ten": {
      "$ref": "#/$defs/tenConfiguration"
    }
    // @}
  },
  "additionalProperties": {
    "anyOf": [
      {
        "type": "string"
      },
      {
        "type": "number"
      },
      {
        "type": "object",
        "$ref": "#/$defs/validPropertyObject"
      },
      {
        "type": "array",
        "items": {
          "$ref": "#/$defs/validPropertyArrayItem"
        }
      },
      {
        "type": "boolean"
      }
    ]
  }
}